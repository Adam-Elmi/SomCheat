---
import { ArrowRightLongIcon } from "../React/icons/Arrow_Icons";
const { url, title } = Astro.props;
---

<div class="flex items-start p-3 group hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors duration-200">
	<div class="shrink-0 mr-4 mt-1 text-indigo-500">
		<ArrowRightLongIcon dimension={20} />
	</div>
	<div class="flex-1">
		<a
			href={url}
			target="_blank"
			rel="noopener noreferrer"
			class="block text-lg font-semibold text-slate-700 dark:text-slate-200 group-hover:text-indigo-600 transition-colors duration-300"
		>
			{title}
		</a>
		<span class="mt-1 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
			<slot />
		</span>
	</div>
</div>
