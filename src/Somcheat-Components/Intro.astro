---
import CheatsheetMetadata from "../Components/CheatsheetMetadata.astro";
import metadata from "../../data/metadata.json";
import { formatDate } from "../utils/formatDate";

export interface CheatsheetFrontmatter {
	title: string;
	description?: string;
	order?: number;
	draft?: boolean;
}

export interface CheatsheetFrontmatter {
	layout: string;
	title: string;
	version: string;
	release: number;
	author: string;
	category: string;
}

export interface CheatsheetEntry {
	slug: string;
	frontmatter: CheatsheetFrontmatter;
	url: string;
}

// Languages
const languages_module = import.meta.glob<{
	frontmatter: CheatsheetFrontmatter;
}>("../pages/cheatsheets/languages/*.mdx", { eager: true });

// Databases
const databases_module = import.meta.glob<{
	frontmatter: CheatsheetFrontmatter;
}>("../pages/cheatsheets/databases/*.mdx", { eager: true });

// Frameworks
const frameworks_module = import.meta.glob<{
	frontmatter: CheatsheetFrontmatter;
}>("../pages/cheatsheets/frameworks/*.mdx", { eager: true });

// Libraries
const libraries_module = import.meta.glob<{
	frontmatter: CheatsheetFrontmatter;
}>("../pages/cheatsheets/libraries/*.mdx", { eager: true });

// Platforms
const platforms_module = import.meta.glob<{
	frontmatter: CheatsheetFrontmatter;
}>("../pages/cheatsheets/platforms/*.mdx", { eager: true });

// Runtimes
const runtimes_module = import.meta.glob<{
	frontmatter: CheatsheetFrontmatter;
}>("../pages/cheatsheets/runtimes/*.mdx", { eager: true });

// Dev-Tools
const devTools_module = import.meta.glob<{
	frontmatter: CheatsheetFrontmatter;
}>("../pages/cheatsheets/devtools/*.mdx", { eager: true });

// Other
const other_module = import.meta.glob<{
	frontmatter: CheatsheetFrontmatter;
}>("../pages/cheatsheets/other/*.mdx", { eager: true });
const modules = [
	languages_module,
	databases_module,
	frameworks_module,
	libraries_module,
	platforms_module,
	runtimes_module,
	devTools_module,
	other_module
];
const cheatsheet_modules: any = {};
for (const module of modules) {
	for (const key in module) {
		cheatsheet_modules[key] = module[key];
	}
}

const cheatsheets: CheatsheetEntry[] = Object.entries(cheatsheet_modules).map(([path, module]) => {
	const slug = path
		.split("/")
		.pop()!
		.replace(/\.mdx$/, "");
	// @ts-ignore
	return { slug, frontmatter: module.frontmatter, url: module.url };
});

const currentPathSegments = Astro.originPathname.split("/").filter(segment => segment.length > 0);

const currentSlug = currentPathSegments.length > 0 ? currentPathSegments[currentPathSegments.length - 1] : null;

const currentFile: CheatsheetEntry | null = currentSlug ? (cheatsheets.find(file => file.slug === currentSlug) ?? null) : null;

const { title, version, release, author, category } = currentFile?.frontmatter ?? {
	title: "Unknown",
	version: "Unknown",
	release: "Unknown",
	author: "Unknown",
	category: "Unknown"
};
const authors = author && typeof author === "string" ? author.split(",") : author;

let lastUpdated = "Unknown";
let updatedBy = "Unknown";

try {
	const pathname = Astro.url.pathname;
	const id = pathname
		.split("/")
		.filter(p => p && p !== "cheatsheets")
		.pop();

	if (id) {
		// @ts-ignore
		const metadataKey = `src/pages${currentFile.url}.mdx`;
		// @ts-ignore
		let meta = metadata[metadataKey];

		if (meta) {
			if (meta.lastUpdated) {
				lastUpdated = formatDate(meta.lastUpdated);
			}
			if (meta.updatedBy) {
				updatedBy = meta.updatedBy;
			}
		}
	}
} catch (e) {
	console.error("Error determining date in Intro.astro", e);
}
---

<CheatsheetMetadata {lastUpdated} {updatedBy} {title} {category} {version} {release} {authors} {author}>
	<slot />
</CheatsheetMetadata>
